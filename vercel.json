{
  "version": 2,
  "buildCommand": "node artifacts/api-server/build.vercel.mjs && pnpm --filter @workspace/rca-app run build",
  "outputDirectory": "artifacts/rca-app/dist/public",
  "build": {
    "env": {
      "PORT": "3000",
      "BASE_PATH": "/"
    }
  },
  "functions": {
    "artifacts/api-server/dist/vercel-app.cjs": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/dist/vercel-app.cjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
